@startuml
show members

' Configurações para um design mais limpo, estruturado e com linhas retas
skinparam linetype ortho
skinparam nodesep 70
skinparam ranksep 80
skinparam shadowing false
skinparam classBackgroundColor White
skinparam classBorderColor Black
skinparam packageStyle rectangle

package "Controle de Acesso" {
    class Usuario {
      - nome: String
      - email: String
      - telefone: String
      - login: String
      - senha: String
      - dataNascimento: Date
      - genero: String
      - endereco: String
      - cpf: String
      + cadastrarUsuario(): void
      + login(): boolean
      + logout(): void
      + atualizarPerfil(): void
    }

    class Hospede {
      - pontosFidelidade: int
      + consultarHistoricoEstadias(): List<Reserva>
    }

    class Atendente {
      - numeroDeCadastro: String
      + realizarCheckIn(reserva: Reserva): void
      + realizarCheckOut(reserva: Reserva): void
    }

    class Gestor {
      - nivelPermissao: String
      + emitirRelatorioFaturamento(): void
      + alterarTarifa(categoria: CategoriaQuarto, novoPreco: Double): void
    }

    Usuario <|-- Hospede
    Usuario <|-- Atendente
    Usuario <|-- Gestor
}

package "Hospedagem e Infraestrutura" {
    class Hotel {
      - nome: String
      - cnpj: String
      - endereco: String
      - telefoneContato: String
      + atualizarDados(): void
    }

    class CategoriaQuarto {
      - nome: String
      - capacidade: Integer
      - precoDiaria: Double
      + criarCategoria(): void
      + atualizarCategoria(nome: String, preco: Double): void
      + removerCategoria(nome: String): void
    }

    class Quarto {
      - numero: String
      - status: StatusQuarto
      + cadastrarQuarto(categoria: CategoriaQuarto): void
      + atualizarStatus(novoStatus: StatusQuarto): void
      + consultarDisponibilidade(): boolean
      + removerQuarto(numero: String): void
    }

    class Reserva {
      - dataEntrada: Date
      - dataSaida: Date
      - status: StatusReserva
      + criarReserva(hospede: Hospede, quarto: Quarto): void
      + cancelarReserva(): void
      + confirmarPagamento(): void
    }

    enum StatusQuarto {
      DISPONIVEL
      OCUPADO
      LIMPEZA
      MANUTENCAO
    }

    enum StatusReserva {
      PENDENTE
      CONFIRMADA
      FINALIZADA
      CANCELADA
    }

    Hotel "1" *-- "*" Quarto : possui >
    Hotel "1" *-- "*" CategoriaQuarto : oferece >
    Quarto "*" -- "1" CategoriaQuarto : pertence a >
    Reserva "*" -- "1" Quarto : aloca >
    
    StatusQuarto .. Quarto
    StatusReserva .. Reserva
}

package "Financeiro e Restaurante" {
    class ContaHospedagem {
      - dataAbertura: Date
      - totalAcumulado: Double
      - status: StatusReserva
      + abrirConta(): void
      + fecharConta(): void
      + calcularTotal(): Double
    }

    class Pedido {
      - dataHora: DateTime
      - tipo: String
      + adicionarItem(produto: Produto, qtd: int): void
      + calcularTotalPedido(): Double
    }

    class ItemPedido {
      - quantidade: Integer
      - precoPraticado: Double
      + calcularSubtotal(): Double
    }

    class Produto {
      - nome: String
      - categoria: String
      - precoAtual: Double
    }

    ContaHospedagem "1" -- "*" Pedido : recebe >
    Pedido "1" *-- "*" ItemPedido : contém >
    ItemPedido "*" -- "1" Produto : refere-se a >
}

' Relacionamentos entre pacotes (Forçados para roteamento limpo)
Gestor "1" -down- "1" Hotel : administra >
Atendente "*" -down- "1" Hotel : trabalha no >
Hospede "1" -- "*" Reserva : solicita >
Atendente "1" -- "*" Reserva : processa >
Reserva "1" -down- "1" ContaHospedagem : possui >
Atendente "1" -down- "*" Pedido : registra >

@enduml